{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/subjects", "destination": "/subjects.html" },
    { "source": "/content", "destination": "/content.html" },
    { "source": "/stream", "destination": "/stream.html" },
    { "source": "/schedule-details", "destination": "/schedule-details.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/batches", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization,X-PW-Token" },
        { "key": "Cache-Control", "value": "s-maxage=60, stale-while-revalidate=300" }
      ]
    }
  ],
  "functions": {
    "api/pw.js": {
      "maxDuration": 30
    },
    "api/auth.js": {
      "maxDuration": 15
    },
    "api/media.js": {
      "maxDuration": 30
    }
  }
}
